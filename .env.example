# ── Обязательно ──────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ── На Railway не нужно задавать вручную ─────────────────────────────────────
# DATABASE_URL заполняется автоматически при добавлении PostgreSQL плагина
# WEBHOOK_URL определяется из RAILWAY_PUBLIC_DOMAIN автоматически
# PORT задаётся Railway автоматически

# ── Опционально ───────────────────────────────────────────────────────────────
# Твой Telegram user ID (найди через @userinfobot) — для /admin команды
ADMIN_IDS=123456789

# Секрет для проверки, что вебхук дёргает реально Telegram, а не злоумышленник.
# Можно НЕ задавать — тогда секрет автоматически выводится из BOT_TOKEN.
# Если хочешь задать вручную: 1–256 символов из набора A-Z a-z 0-9 _ -
# Сгенерировать можно так:  openssl rand -hex 32
# WEBHOOK_SECRET=СЮДА_ВСТАВИТЬ_СЛУЧАЙНУЮ_СТРОКУ

# Канал обязательной подписки (gate). По умолчанию @cyber_mind_best.
# REQUIRED_CHANNEL=@your_channel
# REQUIRED_CHANNEL_URL=https://t.me/your_channel

# ── Связь с Cursor (команда /cursor, только для админов) ──────────────────────
# Ключ Cursor API: Cursor Dashboard → Integrations → API Keys (формат cursor_...)
# Без него команда /cursor просто скажет «не настроено», остальной бот работает.
# CURSOR_API_KEY=СЮДА_ВСТАВИТЬ_КЛЮЧ_CURSOR

# Репозиторий, над которым работает облачный агент Cursor (по умолчанию — этот).
# CURSOR_REPO_URL=https://github.com/ciseuadm/Boot-Name-.git
# CURSOR_REPO_REF=main

# Модель: auto (по умолчанию) — Cursor сам выбирает (Sonnet/Opus/Max).
# CURSOR_MODEL=auto

# Открывать ли PR на каждую задачу (true по умолчанию). false — работать без PR.
# CURSOR_AUTO_PR=true

# ── Локальная разработка ──────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/buttonbot
# WEBHOOK_URL=https://your-ngrok-url.ngrok.io
# PORT=3000
